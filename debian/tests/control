# autopkgtest for proximo. One smoke test: install the package for real
# (dh-virtualenv venv + /usr/bin/proximo symlink) and run `proximo doctor`
# against an address nothing is listening on, so the test never needs a
# real Proxmox host. It only asserts the bundled venv actually starts and
# `doctor` walks its full read-only preflight and prints a JSON report --
# not that the (nonexistent) target is reachable.
Tests: smoke
Depends: @
Restrictions: allow-stderr
