# Proximo configuration — copy to /etc/proximo/proximo.env (chmod 600).

# --- Management (Proxmox REST API) ---
PROXIMO_API_BASE_URL=https://pve.example.lan:8006/api2/json
PROXIMO_NODE=pve

# Path to a file containing exactly: USER@REALM!TOKENID=SECRET
# (run-but-not-read; chmod 600, owned by the proximo user)
PROXIMO_TOKEN_PATH=/etc/proximo/pve-token

# --- Exec (ssh -> pct) ---
# "pve" = remote via ssh host alias; "local" = on the PVE host (direct pct)
PROXIMO_SSH_TARGET=pve

# --- Safety ---
# In-container exec (ssh -> pct) is OFF by default — Proximo is API-only and safe out of the box.
# Set to 1 ONLY if you want the exec edge; it grants near-root on the PVE host, so scope the
# ssh user and set a CTID allowlist below.
PROXIMO_ENABLE_EXEC=false

# Comma-separated CTIDs. Empty = DENY all (fail-closed). "*" = allow all (warns).
PROXIMO_CT_ALLOWLIST=

# --- qemu-agent (in-VM ops via the QEMU Guest Agent) ---
# OFF by default. Set to 1 ONLY to enable in-guest VM ops (exec / file read+write / fsfreeze /
# set-user-password). Like exec, it grants near-root INSIDE the guest, so scope the VMID allowlist.
# Requires the guest to have qemu-guest-agent installed + running (and agent=1 in the VM config).
PROXIMO_ENABLE_AGENT=false

# Comma-separated VMIDs. Empty = DENY all (fail-closed). "*" = allow all (warns).
# Independent of the CTID allowlist above — VM-agent ops and LXC exec are scoped separately.
PROXIMO_AGENT_ALLOWLIST=

PROXIMO_AUDIT_LOG=/var/log/proximo/audit.log
# PROVE ledger: keyed (HMAC) chaining is ON by default. Opt out with PROXIMO_AUDIT_KEYED=off.
# Key auto-generated 0600 at <audit-log-dir>/audit.key (override with PROXIMO_AUDIT_KEY_PATH).
# An existing unkeyed log is sealed + archived (never deleted) and a fresh keyed log started.
#PROXIMO_AUDIT_KEYED=off
#PROXIMO_AUDIT_KEY_PATH=/var/lib/proximo/audit.key
# Pin your ledger head OFF-BOX to detect tail truncation/forged-append/wipe (the strong guarantee).
# Read it from audit_verify's "head" field, store it somewhere the box can't rewrite, set it here:
#PROXIMO_AUDIT_EXPECTED_HEAD=<64-hex head() value>
# NOTE: enabling keyed mode on an existing unkeyed ledger rotates it to a NEW head — re-pin this
# after a keyed upgrade (the migration warning prints the new head).
PROXIMO_VERIFY_TLS=true
# Prefer a CA bundle over disabling TLS verification:
# PROXIMO_CA_BUNDLE=/etc/proximo/pve-ca.crt
# Or pin the node cert directly — WIRE-ENFORCED: the SHA-256 must match exactly (the form
# the PVE GUI shows), replacing CA/hostname validation. Strongest for a self-signed PVE node
# whose cert is signed by the per-cluster "PVE Cluster Manager CA" no public root trusts.
# PROXIMO_FINGERPRINT=AA:BB:CC:...

# --- PBS (Proxmox Backup Server) — optional, only needed for pbs_* tools ---
# PROXIMO_PBS_BASE_URL=https://pbs.example.lan:8007/api2/json
# PROXIMO_PBS_TOKEN_PATH=/etc/proximo/pbs-token
# PROXIMO_PBS_VERIFY_TLS=true
# PROXIMO_PBS_CA_BUNDLE=/etc/proximo/pbs-ca.crt
# Fingerprint pinning is WIRE-ENFORCED: when set, the server cert's SHA-256 must match
# exactly (the form the PBS GUI shows) — replaces CA/hostname validation, refuses on
# mismatch before the token is sent. The strongest option for a self-signed PBS box.
# PROXIMO_PBS_FINGERPRINT=AA:BB:CC:...

# --- PMG (Proxmox Mail Gateway) — optional, only needed for pmg_* tools ---
# Ticket-based auth confirmed against PMG 9.1 (cookie PMGAuthCookie, CSRF on writes, no API tokens).
# PROXIMO_PMG_BASE_URL=https://pmg.example.lan:8006/api2/json
# PROXIMO_PMG_PASSWORD_PATH=/etc/proximo/pmg-password
# PROXIMO_PMG_USERNAME=root@pam
# PROXIMO_PMG_NODE=pmg
# PROXIMO_PMG_VERIFY_TLS=true
# PROXIMO_PMG_CA_BUNDLE=/etc/proximo/pmg-ca.crt
# Or pin the cert (WIRE-ENFORCED — exact SHA-256 match, strongest for a self-signed PMG):
# PROXIMO_PMG_FINGERPRINT=AA:BB:CC:...

# --- PDM (Proxmox Datacenter Manager) — optional, only needed for pdm_* tools ---
# Auth: PDMAPIToken TOKENID:SECRET (space separator — not '=' like PVE/PBS)
# /api2/json is appended automatically if the URL has no path.
# PROXIMO_PDM_BASE_URL=https://pdm.example.com:8443
# PROXIMO_PDM_TOKEN_PATH=/etc/proximo/pdm-token
# PROXIMO_PDM_VERIFY_TLS=true
# PROXIMO_PDM_CA_BUNDLE=/etc/proximo/pdm-ca.crt
# Or pin the cert (WIRE-ENFORCED — exact SHA-256 match, strongest for a self-signed PDM):
# PROXIMO_PDM_FINGERPRINT=AA:BB:CC:...

# --- Network faces (A2A / HTTP / MCP-over-streamable-HTTP) — optional, opt-in per face ---
# Each face is its own command (proximo-a2a / proximo-http / proximo-mcp-http) and only
# listens when YOU start it — nothing in this section opens a port by itself. All three
# share one fail-closed perimeter (proximo.webguard): a non-localhost *_HOST REFUSES to
# start without its *_TOKEN_FILE (inbound bearer, run-but-not-read; chmod 600 — a separate
# secret from the Proxmox API tokens above: this one is what YOUR CLIENTS present to
# Proximo). *_ALLOWED_HOSTS is the Host allowlist for the DNS-rebind guard — set it to the
# hostname your reverse proxy forwards; an explicit list REPLACES the loopback default, so
# include localhost/the container name if healthchecks hit those. Setup walkthrough:
# SETUP.md "Remote / multi-client".

# A2A (Agent2Agent) — proximo-a2a, [a2a] extra
# PROXIMO_A2A_HOST=127.0.0.1
# PROXIMO_A2A_PORT=41241
# PROXIMO_A2A_TOKEN_FILE=/etc/proximo/a2a-bearer.token
# PROXIMO_A2A_ALLOWED_HOSTS=
# Sign the agent card (optional; EC P-256 private key, chmod 600):
# PROXIMO_A2A_SIGNING_KEY_FILE=/etc/proximo/a2a-signing.key

# HTTP/OpenAPI (REST for no-code clients) — proximo-http, [http] extra
# PROXIMO_HTTP_HOST=127.0.0.1
# PROXIMO_HTTP_PORT=41242
# PROXIMO_HTTP_TOKEN_FILE=/etc/proximo/http-bearer.token
# PROXIMO_HTTP_ALLOWED_HOSTS=

# MCP over Streamable HTTP (networked MCP clients, no bridge) — proximo-mcp-http, [mcp-http] extra
# PROXIMO_MCP_HTTP_HOST=127.0.0.1
# PROXIMO_MCP_HTTP_PORT=41243
# PROXIMO_MCP_HTTP_TOKEN_FILE=/etc/proximo/mcp-bearer.token
# PROXIMO_MCP_HTTP_ALLOWED_HOSTS=
# Stateless serving is the DEFAULT (multi-client behind a proxy is the deployment model).
# Opt out for session-stateful serving:
# PROXIMO_MCP_HTTP_STATELESS=0
# Answer POSTs with plain JSON instead of SSE, for clients that prefer it:
# PROXIMO_MCP_HTTP_JSON=1
