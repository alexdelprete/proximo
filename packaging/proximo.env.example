# Proximo configuration — copy to /etc/proximo/proximo.env (chmod 600).

# --- Management (Proxmox REST API) ---
PROXIMO_API_BASE_URL=https://pve.example.lan:8006/api2/json
PROXIMO_NODE=pve

# Path to a file containing exactly: USER@REALM!TOKENID=SECRET
# (run-but-not-read; chmod 600, owned by the proximo user)
PROXIMO_TOKEN_PATH=/etc/proximo/pve-token

# --- Exec (ssh -> pct) ---
# "pve" = remote via ssh host alias; "local" = on the PVE host (direct pct)
PROXIMO_SSH_TARGET=pve

# --- Safety ---
# In-container exec (ssh -> pct) is OFF by default — Proximo is API-only and safe out of the box.
# Set to 1 ONLY if you want the exec edge; it grants near-root on the PVE host, so scope the
# ssh user and set a CTID allowlist below.
PROXIMO_ENABLE_EXEC=false

# Comma-separated CTIDs. Empty = DENY all (fail-closed). "*" = allow all (warns).
PROXIMO_CT_ALLOWLIST=

# --- qemu-agent (in-VM ops via the QEMU Guest Agent) ---
# OFF by default. Set to 1 ONLY to enable in-guest VM ops (exec / file read+write / fsfreeze /
# set-user-password). Like exec, it grants near-root INSIDE the guest, so scope the VMID allowlist.
# Requires the guest to have qemu-guest-agent installed + running (and agent=1 in the VM config).
PROXIMO_ENABLE_AGENT=false

# Comma-separated VMIDs. Empty = DENY all (fail-closed). "*" = allow all (warns).
# Independent of the CTID allowlist above — VM-agent ops and LXC exec are scoped separately.
PROXIMO_AGENT_ALLOWLIST=

PROXIMO_AUDIT_LOG=/var/log/proximo/audit.log
# PROVE ledger: keyed (HMAC) chaining is ON by default. Opt out with PROXIMO_AUDIT_KEYED=off.
# Key auto-generated 0600 at <audit-log-dir>/audit.key (override with PROXIMO_AUDIT_KEY_PATH).
# An existing unkeyed log is sealed + archived (never deleted) and a fresh keyed log started.
#PROXIMO_AUDIT_KEYED=off
#PROXIMO_AUDIT_KEY_PATH=/var/lib/proximo/audit.key
# Pin your ledger head OFF-BOX to detect tail truncation/forged-append/wipe (the strong guarantee).
# Read it from audit_verify's "head" field, store it somewhere the box can't rewrite, set it here:
#PROXIMO_AUDIT_EXPECTED_HEAD=<64-hex head() value>
# NOTE: enabling keyed mode on an existing unkeyed ledger rotates it to a NEW head — re-pin this
# after a keyed upgrade (the migration warning prints the new head).
PROXIMO_VERIFY_TLS=true
# Prefer a CA bundle over disabling TLS verification:
# PROXIMO_CA_BUNDLE=/etc/proximo/pve-ca.crt

# --- PBS (Proxmox Backup Server) — optional, only needed for pbs_* tools ---
# PROXIMO_PBS_BASE_URL=https://pbs.example.lan:8007/api2/json
# PROXIMO_PBS_TOKEN_PATH=/etc/proximo/pbs-token
# PROXIMO_PBS_VERIFY_TLS=true
# PROXIMO_PBS_CA_BUNDLE=/etc/proximo/pbs-ca.crt
# PROXIMO_PBS_FINGERPRINT=AA:BB:CC:...

# --- PMG (Proxmox Mail Gateway) — optional, only needed for pmg_* tools ---
# Ticket-based auth confirmed against PMG 9.1 (cookie PMGAuthCookie, CSRF on writes, no API tokens).
# PROXIMO_PMG_BASE_URL=https://pmg.example.lan:8006/api2/json
# PROXIMO_PMG_PASSWORD_PATH=/etc/proximo/pmg-password
# PROXIMO_PMG_USERNAME=root@pam
# PROXIMO_PMG_NODE=pmg
# PROXIMO_PMG_VERIFY_TLS=true
# PROXIMO_PMG_CA_BUNDLE=/etc/proximo/pmg-ca.crt
